{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "client/api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/login",
      "dest": "/client/api/auth/login.js"
    },
    {
      "src": "/api/products",
      "dest": "/client/api/products/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/client/build/$1"
    }
  ],
  "env": {
    "JWT_SECRET": "your-super-secret-jwt-key-change-in-production",
    "DB_NAME": "ecommerceai"
  }
}
