{
  "scripts": {
    "build": "cd client && npm install && npm run build",
    "start": "cd server && npm start",
    "start:django": "cd django-backend && python manage.py runserver 8000",
    "start:frontend": "cd client && npm start",
    "start:dev": "concurrently \"npm run start:django\" \"npm run start:frontend\""
  },
  "dependencies": {
    "mongoose": "^9.3.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
